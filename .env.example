# Variables d'environnement — Exposition Ombres & Lumières
# Copier dans Vercel > Settings > Environment Variables
# Ne jamais commiter ce fichier avec de vraies valeurs

# Secret JWT — générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacer_par_une_chaine_aleatoire_longue_et_secrete

# Identifiants admin
ADMIN_USER=admin
ADMIN_PASSWORD=remplacer_par_un_mot_de_passe_fort
